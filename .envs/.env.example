# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        OUIJA — ENVIRONMENT VARIABLES                        ║
# ║  Copy this file to .env and fill in your values before running the app.     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ouija
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ouija
DATABASE_URL=postgresql://ouija:changeme@postgres:5432/ouija

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_HOST=redis
REDIS_PORT=6379

# ── App URL (used in email links) ─────────────────────────────────────────────
# The public-facing URL of your web app (no trailing slash).
# Email verification and password-reset links will point here.
APP_URL=http://localhost:3000

# ── Auth feature flags ────────────────────────────────────────────────────────
# Set to "true" to enable. Both default to false.
#
# AUTH_REQUIRE_EMAIL_VERIFICATION
#   Newly registered accounts must verify their email before they are active.
#   Requires SMTP to be configured below.
#
# AUTH_ENABLE_PASSWORD_RESET
#   The "forgot password" flow is available on the login page.
#   Requires SMTP to be configured below.
#
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_ENABLE_PASSWORD_RESET=false

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Only needed when either auth flag above is "true".
# See .env.smtp.gmail, .env.smtp.outlook, .env.smtp.generic for ready-to-use
# provider templates you can paste from.
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Ouija <noreply@example.com>
